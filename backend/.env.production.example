# Configuration de base de données pour Render (PostgreSQL)
DATABASE_URL=postgresql://username:password@hostname:port/database_name

# Sécurité - Générer une clé secrète forte
SECRET_KEY=your-very-long-secret-key-at-least-32-characters-long

# Configuration JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environnement
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Redis pour rate limiting (fourni par Render)
REDIS_URL=redis://hostname:port/0

# Rate limiting
ENABLE_RATE_LIMITING=true
DEFAULT_RATE_LIMIT=100/minute

# CORS - Remplacer par vos vrais domaines (format: chaîne séparée par des virgules)
ALLOW_ORIGINS_STR=https://your-frontend-domain.com,https://your-app.onrender.com

# Stockage audio
AUDIO_STORAGE_PATH=/home/app/audio
MAX_AUDIO_SIZE_MB=10

# AWS S3 (optionnel) - Commenté pour utiliser le stockage local par défaut
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_BUCKET_NAME=your_bucket_name
# AWS_REGION=us-east-1

# Whisper validation (désactivé par défaut pour économiser les ressources)
ENABLE_WHISPER_VALIDATION=false
WHISPER_MODEL=base

# Monitoring (désactivé)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
ENABLE_METRICS=false

# Migration automatique au démarrage (nécessaire pour créer les tables)
RUN_MIGRATIONS=true

# Port (Render définit automatiquement la variable PORT)
PORT=8000
HOST=0.0.0.0
