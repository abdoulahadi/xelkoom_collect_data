# Environment variables
DATABASE_URL=postgresql://username:password@localhost:5432/xelkoom_db

# PostgreSQL docker-compose variables
POSTGRES_USER=username
POSTGRES_PASSWORD=password
POSTGRES_DB=xelkoom_db

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Audio storage
AUDIO_STORAGE_PATH=./audio/
MAX_AUDIO_SIZE_MB=10

# External services (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
USE_S3=false

# Redis (for Celery tasks and rate limiting)
REDIS_URL=redis://localhost:6379/0

# Development settings
DEBUG=True
LOG_LEVEL=INFO
ENVIRONMENT=development  # development, testing, production

# Admin user initial credentials
ADMIN_EMAIL=admin@xelkoom.com
ADMIN_PASSWORD=changeme

# CORS settings
ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO
